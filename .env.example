TG_API_ID=123456
TG_API_HASH=your_api_hash
TG_SESSION=

# Comma-separated list of chat IDs to watch (leave empty to watch all dialogs).
# On first run the app prints all groups & channels with their IDs.
WATCH_CHAT_IDS=

NOTIFY_BOT_TOKEN=123456:abc
MY_CHAT_ID=123456789

KEYWORDS=veber,canon,celestron

# How often (ms) to poll watched chats for new messages. Default 30000.
# Polling is required because gramjs doesn't auto-recover dropped channel updates.
POLL_INTERVAL_MS=30000

# Path to the SQLite file used for dedup state. Default notifications.db.
DB_PATH=notifications.db

# How many days to keep dedup rows. Older rows are pruned daily. Default 60.
RETENTION_DAYS=60
